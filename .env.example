# Clerk — use pk_test_/sk_test_ locally, pk_live_/sk_live_ in GitHub Actions for production
# https://dashboard.clerk.com → switch to Production instance for live keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Set false to force free mode even when Clerk keys exist
NEXT_PUBLIC_SUBSCRIPTION_ENABLED=true

# World Cup free promo (ended) — leave false unless re-enabling a launch window
NEXT_PUBLIC_WORLD_CUP_FREE_ENABLED=false
NEXT_PUBLIC_WORLD_CUP_FREE_UNTIL=2026-07-20T23:59:59Z

# Tipster outreach links: https://statmanac.com/football/premier-league/builder/?ref=andyrobson&utm_medium=tipster&utm_campaign=epl_launch

# One-shot PL season reminder (Actions: workflow_dispatch only)
# REMINDER_FROM_EMAIL=Statmanac <updates@statmanac.com>
# RESEND_API_KEY=
# CLERK_SECRET_KEY=

# Existing data pipelines (unchanged)
RACING_API_USERNAME=
RACING_API_PASSWORD=
# Fetch real horse history for today's cards (top N runners per race). Quota-heavy.
RACING_FETCH_HISTORY=false
RACING_HISTORY_PER_RACE=3
TAVILY_API_KEY=
ODDS_API_IO_KEY=

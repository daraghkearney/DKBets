# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Set false to force free mode even when Clerk keys exist
NEXT_PUBLIC_SUBSCRIPTION_ENABLED=true

# World Cup launch — unlock football Pro until this UTC datetime (disable with =false)
NEXT_PUBLIC_WORLD_CUP_FREE_ENABLED=true
NEXT_PUBLIC_WORLD_CUP_FREE_UNTIL=2026-07-20T23:59:59Z

# Tipster outreach links: https://statmanac.com/football/world-cup/builder/?ref=andyrobson&utm_medium=tipster&utm_campaign=world_cup_free

# World Cup free-ending emails (GitHub Action: .github/workflows/world-cup-reminder.yml)
# RESEND_API_KEY=          # resend.com — verify statmanac.com domain first
# REMINDER_FROM_EMAIL=Statmanac <noreply@statmanac.com>
# REMINDER_HOURS_BEFORE=48 # send when this many hours remain

# Existing data pipelines (unchanged)
RACING_API_USERNAME=
RACING_API_PASSWORD=
TAVILY_API_KEY=
ODDS_API_IO_KEY=
